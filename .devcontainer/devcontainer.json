{
  "name": "blockyard (Rust)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "dev",
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "mounts": [
    "source=blockyard-cargo-cache,target=/home/dev/.cargo/registry,type=volume",
    "source=blockyard-target,target=/workspace/target,type=volume"
  ],
  "runArgs": ["--env-file", ".devcontainer/.env"],
  "initializeCommand": "mkdir -p .devcontainer/.claude .devcontainer/.ssh",
  "postCreateCommand": {
    "claude": "rm -rf /home/dev/.claude && ln -sf /workspace/.devcontainer/.claude /home/dev/.claude && ln -sf /home/dev/.claude/claude.json /home/dev/.claude.json",
    "gitconfig": "ln -sf /workspace/.devcontainer/.gitconfig /home/dev/.gitconfig",
    "gitexclude": "mkdir -p /workspace/.git/info && ln -sfn ../../.devcontainer/.gitignore /workspace/.git/info/exclude",
    "ssh": "ln -sf /workspace/.devcontainer/.ssh /home/dev/.ssh && chmod 700 /home/dev/.ssh && find /home/dev/.ssh -type f ! -name '*.pub' ! -name known_hosts ! -name config -exec chmod 600 {} +"
  }
}
